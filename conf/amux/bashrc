# amux panel shell — minimal, deterministic
bind 'set enable-bracketed-paste on' 2>/dev/null
__amux_prompt() {
  local ec=$?
  local name="${AMUX_PANEL:-amux}"
  # Emit sentinel on its own line, then the prompt.
  printf '\nAMUX_DONE:%d:%s\n' "$ec" "$name"
  if [ $ec -eq 0 ]; then
    PS1="$name \\$ "
  else
    PS1="$name [exit $ec] \\$ "
  fi
}
PROMPT_COMMAND=__amux_prompt
